{
  "name": "storybook-addon-launchdarkly",
  "version": "4.0.0",
  "homepage": "https://github.com/kodai3/storybook-addon-launchdarkly#readme",
  "description": "Use Launchdarkly in your Storybook stories.",
  "type": "module",
  "license": "MIT",
  "author": "kodai3",
  "exports": {
    "./preview": "./dist/preview.js",
    "./manager": "./dist/manager.js",
    "./package.json": "./package.json"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "manager.js",
    "preview.js"
  ],
  "keywords": [
    "storybook",
    "addon",
    "launchdarkly"
  ],
  "storybook": {
    "displayName": "Launchdarkly",
    "icon": "https://pbs.twimg.com/profile_images/1440353941447856132/1NSTAyVX_400x400.jpg"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kodai3/storybook-addon-launchdarkly.git"
  },
  "bugs": {
    "url": "https://github.com/kodai3/storybook-addon-launchdarkly/issues"
  },
  "scripts": {
    "build": "tsc --build",
    "clean": "rimraf dist",
    "prebuild": "npm run clean",
    "test": "vitest run",
    "storybook": "storybook dev -p 6006",
    "lint": "eslint .",
    "predeploy": "npm run build-storybook",
    "deploy": "gh-pages -d storybook-static",
    "build-storybook": "storybook build",
    "start-storybook": "storybook dev",
    "prepare": "husky install"
  },
  "dependencies": {
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@storybook/addon-links": "^10.0.0",
    "@storybook/addon-webpack5-compiler-swc": "^4.0.0",
    "@storybook/react": "^10.0.0",
    "@storybook/react-webpack5": "^10.0.0",
    "@swc/core": "^1.10.14",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/react": "^19.0.8",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.44.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-react": "^7.32.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "gh-pages": "^5.0.0",
    "husky": "^8.0.3",
    "jsdom": "^29.0.2",
    "launchdarkly-react-client-sdk": "3.0.6",
    "prettier": "^3.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rimraf": "^5.0.1",
    "storybook": "^10.0.0",
    "typescript": "5.1.6",
    "vitest": "^4.1.4"
  },
  "peerDependencies": {
    "launchdarkly-react-client-sdk": ">=3.0.0 <3.0.7",
    "react": "^17.0.0 || ^18.0.0 || ^19.0.0",
    "react-dom": "^17.0.0 || ^18.0.0 || ^19.0.0",
    "storybook": "^10.0.0"
  }
}
